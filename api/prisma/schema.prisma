generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & RBAC ====================

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum MemberTier {
  DEAL_HUNTER
  DEAL_SCOUT
  DEAL_MASTER
  DEAL_LEGEND
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String       @map("password_hash")
  name          String
  username      String?      @unique
  nickname      String?
  bio           String?      @db.Text
  avatar        String?
  dealScore     Int          @default(0) @map("deal_score")
  tier          MemberTier   @default(DEAL_HUNTER)
  expertiseTags Json?        @map("expertise_tags")
  role          UserRole     @default(USER)
  status        UserStatus   @default(ACTIVE)
  emailVerified Boolean      @default(false) @map("email_verified")
  refreshToken  String?      @map("refresh_token") @db.Text
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  wishlists     Wishlist[]
  priceAlerts   PriceAlert[]
  affiliateClicks AffiliateClick[]
  compareLists  CompareList[]
  boardPosts    BoardPost[]
  boardComments BoardComment[]
  boardPostUpvotes BoardPostUpvote[]

  @@index([dealScore])
  @@index([tier])
  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")

  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  resource    String
  action      String
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ==================== MARKETPLACE & PRODUCTS ====================

enum Marketplace {
  SHOPEE
  LAZADA
  TIKTOK_SHOP
  OTHER
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  icon        String?
  image       String?
  parentId    String?    @map("parent_id")
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Product {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  description     String?     @db.Text
  imageUrl        String?     @map("image_url")
  images          Json?
  categoryId      String?     @map("category_id")
  brand           String?
  rating          Decimal?    @db.Decimal(3, 2)
  reviewCount     Int         @default(0) @map("review_count")
  soldCount       Int         @default(0) @map("sold_count")
  isTrending      Boolean     @default(false) @map("is_trending")
  isTopSelling    Boolean     @default(false) @map("is_top_selling")
  searchKeywords  String?     @map("search_keywords") @db.Text
  aiReviewSummary String?     @map("ai_review_summary") @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  category        Category?         @relation(fields: [categoryId], references: [id])
  listings        ProductListing[]
  priceHistory    PriceHistory[]
  wishlists       Wishlist[]
  priceAlerts     PriceAlert[]
  affiliateClicks AffiliateClick[]
  compareItems    CompareItem[]
  boardPosts      BoardPost[]

  @@index([categoryId])
  @@index([isTrending])
  @@index([isTopSelling])
  @@index([soldCount])
  @@fulltext([name, searchKeywords])
  @@map("products")
}

model ProductListing {
  id              String      @id @default(cuid())
  productId       String      @map("product_id")
  marketplace     Marketplace
  externalId      String      @map("external_id")
  title           String
  price           Decimal     @db.Decimal(12, 2)
  originalPrice   Decimal?    @map("original_price") @db.Decimal(12, 2)
  currency        String      @default("THB")
  affiliateUrl    String      @map("affiliate_url") @db.Text
  shopName        String?     @map("shop_name")
  shopUrl         String?     @map("shop_url") @db.Text
  rating          Decimal?    @db.Decimal(3, 2)
  soldCount       Int         @default(0) @map("sold_count")
  stock           Int?
  isAvailable     Boolean     @default(true) @map("is_available")
  lastSyncedAt    DateTime?   @map("last_synced_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceHistory PriceHistory[]

  @@unique([marketplace, externalId])
  @@index([productId])
  @@index([marketplace])
  @@index([price])
  @@map("product_listings")
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  listingId String?  @map("listing_id")
  price     Decimal  @db.Decimal(12, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  listing ProductListing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  @@index([productId, recordedAt])
  @@index([listingId, recordedAt])
  @@map("price_history")
}

// ==================== USER FEATURES ====================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model PriceAlert {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  productId    String   @map("product_id")
  targetPrice  Decimal  @map("target_price") @db.Decimal(12, 2)
  isActive     Boolean  @default(true) @map("is_active")
  notifiedAt   DateTime? @map("notified_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("price_alerts")
}

model CompareList {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  sessionId String?  @map("session_id")
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  user  User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CompareItem[]

  @@map("compare_lists")
}

model CompareItem {
  id            String @id @default(cuid())
  compareListId String @map("compare_list_id")
  productId     String @map("product_id")
  sortOrder     Int    @default(0) @map("sort_order")

  compareList CompareList @relation(fields: [compareListId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([compareListId, productId])
  @@map("compare_items")
}

// ==================== AFFILIATE & ANALYTICS ====================

model AffiliateClick {
  id          String      @id @default(cuid())
  userId      String?     @map("user_id")
  productId   String      @map("product_id")
  marketplace Marketplace
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent") @db.Text
  referrer    String?     @db.Text
  clickedAt   DateTime    @default(now()) @map("clicked_at")

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([clickedAt])
  @@index([marketplace])
  @@map("affiliate_clicks")
}

model SearchLog {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0)
  userId    String?  @map("user_id")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([query])
  @@index([createdAt])
  @@map("search_logs")
}

model TrendingKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  count     Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("trending_keywords")
}

// ==================== COMMUNITY BOARD ====================

enum BoardPostType {
  DISCUSSION
  DEAL
  REVIEW
  POLL
  FLASH_ALERT
}

model BoardGroup {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  icon        String
  description String      @db.Text
  color       String
  bg          String
  sortOrder   Int         @default(0) @map("sort_order")
  createdAt   DateTime    @default(now()) @map("created_at")

  posts BoardPost[]

  @@map("board_groups")
}

model BoardPost {
  id           String        @id @default(cuid())
  groupId      String        @map("group_id")
  userId       String        @map("user_id")
  productId    String?       @map("product_id")
  postType     BoardPostType @default(DISCUSSION) @map("post_type")
  title        String
  excerpt      String?       @db.Text
  body         String?       @db.Text
  dealPrice    Decimal?      @map("deal_price") @db.Decimal(12, 2)
  affiliateUrl String?       @map("affiliate_url") @db.Text
  platform     String?
  upvoteCount  Int           @default(0) @map("upvote_count")
  commentCount Int           @default(0) @map("comment_count")
  isHot        Boolean       @default(false) @map("is_hot")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  group    BoardGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  comments BoardComment[]
  upvotes  BoardPostUpvote[]

  @@index([groupId, createdAt])
  @@index([isHot])
  @@index([upvoteCount])
  @@map("board_posts")
}

model BoardComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  post BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("board_comments")
}

model BoardPostUpvote {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("board_post_upvotes")
}

// ==================== CMS BANNERS ====================

enum BannerPlacement {
  HERO
}

model Banner {
  id        String          @id @default(cuid())
  placement BannerPlacement @default(HERO)
  title     String?
  imageUrl  String          @map("image_url")
  linkUrl   String          @default("/search") @map("link_url")
  altText   String?         @map("alt_text")
  sortOrder Int             @default(0) @map("sort_order")
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([placement, isActive, sortOrder])
  @@map("banners")
}
